+static int pckb_read_2u8(struct picocalc_keyboard *pckb, u8 reg, u8 *dst)
+{
+	int ret;
+
+	mutex_lock(&pckb->i2c_lock);
+	ret = i2c_smbus_read_word_data(pckb->client, reg);
+	mutex_unlock(&pckb->i2c_lock);
+	if (ret < 0)
+		return ret;
+
+	dst[0] = (u8)(ret & 0xff);
+	dst[1] = (u8)((ret >> 8) & 0xff);
+	return 0;
+}
+
+static int pckb_write_u8(struct picocalc_keyboard *pckb, u8 reg, u8 value)
+{
+	int ret;
+
+	mutex_lock(&pckb->i2c_lock);
+	ret = i2c_smbus_write_byte_data(pckb->client, reg | PICOCALC_WRITE_MASK, value);
+	mutex_unlock(&pckb->i2c_lock);
+
+	return ret;
+}
+
+static int pckb_battery_raw(struct picocalc_keyboard *pckb)
+{
+	u8 data[2];
+
+	return pckb_read_2u8(pckb, REG_ID_BAT, data) < 0 ? -EIO : data[1];
+}
