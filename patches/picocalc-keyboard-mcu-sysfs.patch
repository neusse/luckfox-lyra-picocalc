+static void pckb_shutdown(struct i2c_client *client)
+{
+	struct picocalc_keyboard *pckb = i2c_get_clientdata(client);
+	int ret;
+
+	if (!pckb)
+		return;
+
+	cancel_delayed_work_sync(&pckb->work);
+
+	if (system_state == SYSTEM_RESTART)
+		return;
+
+	ret = pckb_write_u8(pckb, REG_ID_OFF, pckb->poweroff_delay);
+	if (ret)
+		dev_err(&client->dev, "Failed to request PicoCalc poweroff: %d\n", ret);
+	else
+		dev_info(&client->dev, "PicoCalc MCU poweroff requested in %u seconds\n",
+			 pckb->poweroff_delay);
 }
 
