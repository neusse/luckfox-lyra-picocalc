+static ssize_t battery_raw_show(struct device *dev,
+				struct device_attribute *attr, char *buf)
+{
+	struct picocalc_keyboard *pckb = dev_get_drvdata(dev);
+	int raw = pckb_battery_raw(pckb);
+
+	if (raw < 0)
+		return raw;
+
+	return sysfs_emit(buf, "%d\n", raw);
+}
+static DEVICE_ATTR_RO(battery_raw);
+
+static ssize_t battery_percent_show(struct device *dev,
+				    struct device_attribute *attr, char *buf)
+{
+	struct picocalc_keyboard *pckb = dev_get_drvdata(dev);
+	int raw = pckb_battery_raw(pckb);
+
+	if (raw < 0)
+		return raw;
+
+	return sysfs_emit(buf, "%d\n", (int)(raw & ~BIT(7)));
+}
+static DEVICE_ATTR_RO(battery_percent);
+
+static ssize_t battery_status_show(struct device *dev,
+				   struct device_attribute *attr, char *buf)
+{
+	struct picocalc_keyboard *pckb = dev_get_drvdata(dev);
+	int raw = pckb_battery_raw(pckb);
+
+	if (raw < 0)
+		return raw;
+
+	if (raw & BIT(7))
+		return sysfs_emit(buf, "Charging\n");
+	if ((raw & ~BIT(7)) == 100)
+		return sysfs_emit(buf, "Full\n");
+	return sysfs_emit(buf, "Discharging\n");
+}
+static DEVICE_ATTR_RO(battery_status);
+
+static int pckb_parse_u8(const char *buf, u8 *value)
+{
+	unsigned int parsed;
+	int ret;
+
+	ret = kstrtouint(buf, 10, &parsed);
+	if (ret || parsed > 0xff)
+		return -EINVAL;
+
+	*value = parsed;
+	return 0;
+}
+
+static ssize_t pckb_backlight_show(struct device *dev, char *buf, u8 reg)
+{
+	struct picocalc_keyboard *pckb = dev_get_drvdata(dev);
+	u8 data[2];
+	int ret;
+
+	ret = pckb_read_2u8(pckb, reg, data);
+	if (ret < 0)
+		return ret;
+
+	return sysfs_emit(buf, "%u\n", data[1]);
+}
+
+static ssize_t pckb_backlight_store(struct device *dev,
+				    const char *buf, size_t count, u8 reg)
+{
+	struct picocalc_keyboard *pckb = dev_get_drvdata(dev);
+	u8 value;
+	int ret;
+
+	ret = pckb_parse_u8(buf, &value);
+	if (ret)
+		return ret;
+
+	ret = pckb_write_u8(pckb, reg, value);
+	if (ret)
+		return ret;
+
+	return count;
+}
+
+static ssize_t screen_backlight_show(struct device *dev,
+				     struct device_attribute *attr, char *buf)
+{
+	return pckb_backlight_show(dev, buf, REG_ID_BKL);
+}
+static ssize_t screen_backlight_store(struct device *dev,
+				      struct device_attribute *attr,
+				      const char *buf, size_t count)
+{
+	return pckb_backlight_store(dev, buf, count, REG_ID_BKL);
+}
+static DEVICE_ATTR_RW(screen_backlight);
+
+static ssize_t keyboard_backlight_show(struct device *dev,
+				       struct device_attribute *attr, char *buf)
+{
+	return pckb_backlight_show(dev, buf, REG_ID_BK2);
+}
+static ssize_t keyboard_backlight_store(struct device *dev,
+					struct device_attribute *attr,
+					const char *buf, size_t count)
+{
+	return pckb_backlight_store(dev, buf, count, REG_ID_BK2);
+}
+static DEVICE_ATTR_RW(keyboard_backlight);
+
+static ssize_t poweroff_delay_show(struct device *dev,
+				      struct device_attribute *attr, char *buf)
+{
+	struct picocalc_keyboard *pckb = dev_get_drvdata(dev);
+
+	return sysfs_emit(buf,
+		"%u\n", pckb->poweroff_delay);
+}
+
+static ssize_t poweroff_delay_store(struct device *dev,
+				       struct device_attribute *attr,
+				       const char *buf, size_t count)
+{
+	struct picocalc_keyboard *pckb = dev_get_drvdata(dev);
+	u8 delay;
+	int ret;
+
+	ret = pckb_parse_u8(buf, &delay);
+	if (ret)
+		return ret;
+	if (delay > PICOCALC_POWEROFF_MAX_DELAY)
+		return -EINVAL;
+
+	pckb->poweroff_delay = delay;
+
+	return count;
+}
+static DEVICE_ATTR_RW(poweroff_delay);
+
+static struct attribute *pckb_attrs[] = {
+	&dev_attr_battery_raw.attr,
