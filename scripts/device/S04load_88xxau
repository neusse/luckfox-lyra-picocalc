#!/bin/sh
#
# Load RTL8811AU/RTL8821AU USB Wi-Fi support for TP-Link AC600 Nano.

MODULE="/lib/modules/$(uname -r)/extra/88XXau.ko"

case "$1" in
	start)
		if [ -f "$MODULE" ] && ! grep -q '^88XXau ' /proc/modules; then
			insmod "$MODULE" || true
		fi
		;;
	stop)
		if grep -q '^88XXau ' /proc/modules; then
			rmmod 88XXau || true
		fi
		;;
	restart)
		"$0" stop
		"$0" start
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
