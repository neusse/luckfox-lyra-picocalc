#!/bin/sh
set -eu

USER_NAME="${1:-neusse}"
HOME_DIR="$(awk -F: -v user="$USER_NAME" '$1 == user { print $6 }' /etc/passwd)"

if [ -z "$HOME_DIR" ] || [ ! -d "$HOME_DIR" ]; then
	echo "Home directory not found for user: $USER_NAME" >&2
	exit 1
fi

mkdir -p "$HOME_DIR/bin"
mkdir -p "$HOME_DIR/.local/bin"
mkdir -p "$HOME_DIR/tmp"
chown "$USER_NAME:$USER_NAME" "$HOME_DIR/bin"
chown "$USER_NAME:$USER_NAME" "$HOME_DIR/.local" "$HOME_DIR/.local/bin"
chown "$USER_NAME:$USER_NAME" "$HOME_DIR/tmp"
chmod 755 "$HOME_DIR/bin"
chmod 755 "$HOME_DIR/.local" "$HOME_DIR/.local/bin"
chmod 700 "$HOME_DIR/tmp"

cat > "$HOME_DIR/.profile" <<'EOF'
# ~/.profile: login shell setup

if [ -d "$HOME/bin" ]; then
    case ":$PATH:" in
        *":$HOME/bin:"*) ;;
        *) PATH="$HOME/bin:$PATH" ;;
    esac
fi

if [ -d "$HOME/.local/bin" ]; then
    case ":$PATH:" in
        *":$HOME/.local/bin:"*) ;;
        *) PATH="$HOME/.local/bin:$PATH" ;;
    esac
fi

if [ -d "$HOME/tmp" ]; then
    TMPDIR="$HOME/tmp"
fi

if [ -d /usr/local/lib ]; then
    case ":${LD_LIBRARY_PATH:-}:" in
        *":/usr/local/lib:"*) ;;
        *) LD_LIBRARY_PATH="/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" ;;
    esac
fi

export PATH
export TMPDIR
export LD_LIBRARY_PATH
EOF

cat > "$HOME_DIR/.bashrc" <<'EOF'
# ~/.bashrc: interactive shell setup

if [ -d "$HOME/bin" ]; then
    case ":$PATH:" in
        *":$HOME/bin:"*) ;;
        *) PATH="$HOME/bin:$PATH" ;;
    esac
fi

if [ -d "$HOME/.local/bin" ]; then
    case ":$PATH:" in
        *":$HOME/.local/bin:"*) ;;
        *) PATH="$HOME/.local/bin:$PATH" ;;
    esac
fi

if [ -d "$HOME/tmp" ]; then
    TMPDIR="$HOME/tmp"
fi

if [ -d /usr/local/lib ]; then
    case ":${LD_LIBRARY_PATH:-}:" in
        *":/usr/local/lib:"*) ;;
        *) LD_LIBRARY_PATH="/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" ;;
    esac
fi

export PATH
export TMPDIR
export LD_LIBRARY_PATH
EOF

chown "$USER_NAME:$USER_NAME" "$HOME_DIR/.profile" "$HOME_DIR/.bashrc"
chmod 644 "$HOME_DIR/.profile" "$HOME_DIR/.bashrc"

mkdir -p /etc/profile.d
cat > /etc/profile.d/neusse-local-bin.sh <<EOF
# Add Python user paths and runtime library paths on this PicoCalc image.

if [ -d "$HOME_DIR/bin" ]; then
    case ":\$PATH:" in
        *":$HOME_DIR/bin:"*) ;;
        *) PATH="$HOME_DIR/bin:\$PATH" ;;
    esac
fi

if [ -d "$HOME_DIR/.local/bin" ]; then
    case ":\$PATH:" in
        *":$HOME_DIR/.local/bin:"*) ;;
        *) PATH="$HOME_DIR/.local/bin:\$PATH" ;;
    esac
fi

if [ -d "$HOME_DIR/tmp" ]; then
    TMPDIR="$HOME_DIR/tmp"
fi

if [ -d /usr/local/lib ]; then
    case ":\${LD_LIBRARY_PATH:-}:" in
        *":/usr/local/lib:"*) ;;
        *) LD_LIBRARY_PATH="/usr/local/lib\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}" ;;
    esac
fi

export PATH
export TMPDIR
export LD_LIBRARY_PATH
EOF
chmod 644 /etc/profile.d/neusse-local-bin.sh

if [ -d /root ]; then
	cat > /root/.profile <<EOF
# /root/.profile: login shell setup

if [ -d "$HOME_DIR/bin" ]; then
    case ":\$PATH:" in
        *":$HOME_DIR/bin:"*) ;;
        *) PATH="$HOME_DIR/bin:\$PATH" ;;
    esac
fi

if [ -d "$HOME_DIR/.local/bin" ]; then
    case ":\$PATH:" in
        *":$HOME_DIR/.local/bin:"*) ;;
        *) PATH="$HOME_DIR/.local/bin:\$PATH" ;;
    esac
fi

if [ -d "$HOME_DIR/tmp" ]; then
    TMPDIR="$HOME_DIR/tmp"
fi

if [ -d /usr/local/lib ]; then
    case ":\${LD_LIBRARY_PATH:-}:" in
        *":/usr/local/lib:"*) ;;
        *) LD_LIBRARY_PATH="/usr/local/lib\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}" ;;
    esac
fi

export PATH
export TMPDIR
export LD_LIBRARY_PATH
EOF

	cat > /root/.bashrc <<EOF
# /root/.bashrc: interactive shell setup

if [ -d "$HOME_DIR/bin" ]; then
    case ":\$PATH:" in
        *":$HOME_DIR/bin:"*) ;;
        *) PATH="$HOME_DIR/bin:\$PATH" ;;
    esac
fi

if [ -d "$HOME_DIR/.local/bin" ]; then
    case ":\$PATH:" in
        *":$HOME_DIR/.local/bin:"*) ;;
        *) PATH="$HOME_DIR/.local/bin:\$PATH" ;;
    esac
fi

if [ -d "$HOME_DIR/tmp" ]; then
    TMPDIR="$HOME_DIR/tmp"
fi

if [ -d /usr/local/lib ]; then
    case ":\${LD_LIBRARY_PATH:-}:" in
        *":/usr/local/lib:"*) ;;
        *) LD_LIBRARY_PATH="/usr/local/lib\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}" ;;
    esac
fi

export PATH
export TMPDIR
export LD_LIBRARY_PATH
EOF

	chown root:root /root/.profile /root/.bashrc
	chmod 644 /root/.profile /root/.bashrc
fi

echo "Configured Python user paths, TMPDIR, and LD_LIBRARY_PATH for $USER_NAME and root"
