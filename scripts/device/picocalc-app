DEVICE_PATHSEP = ":"


@dataclass(frozen=True)
class AppSpec:
    app: str
    script: str
    args: list[str]
    native: bool = False


def project_root() -> str:
    return os.environ.get("PICOCALC_APP_ROOT", DEFAULT_ROOT)


def venv_root() -> str:
    return os.environ.get("PICOCALC_APP_VENV", DEFAULT_VENV)


def usage() -> str:
    apps = ", ".join(sorted(set(APP_SCRIPTS) | set(NATIVE_APP_COMMANDS)))
    return (
        "usage: picocalc-app <app> [args...]\n"
        "       alpine [args...]\n"
        "       bubble [args...]\n"
        "       breakout [args...]\n"
        "       calculator [args...]\n"
        "       chess [args...]\n"
        "       doom [args...]\n"
        "       minesweeper [args...]\n"
        "       weather [args...]\n"
        "       sudoku [args...]\n"
        "       zork [args...]\n\n"
        f"apps: {apps}\n"
        "examples:\n"
        "  picocalc-app alpine\n"
        "  picocalc-app weather --once\n"
        "  picocalc-app bubble --once\n"
        "  picocalc-app breakout\n"
        "  picocalc-app calculator\n"
        "  picocalc-app chess\n"
        "  picocalc-app doom\n"
        "  picocalc-app clock\n"
        "  picocalc-app launcher\n"
        "  picocalc-app minesweeper\n"
        "  picocalc-app sudoku --demo --once\n"
