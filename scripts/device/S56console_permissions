#!/bin/sh
#
# Allow the non-root development user to write to the PicoCalc console.

fix_console_permissions() {
	for dev in /dev/tty1 /dev/console; do
		if [ -e "$dev" ]; then
			chgrp tty "$dev" 2>/dev/null || true
			chmod 0620 "$dev" 2>/dev/null || true
		fi
	done

	for dev in /dev/input/event*; do
		if [ -e "$dev" ]; then
			chgrp tty "$dev" 2>/dev/null || true
			chmod 0660 "$dev" 2>/dev/null || true
		fi
	done

	if [ -w /sys/class/graphics/fbcon/cursor_blink ]; then
		echo 0 > /sys/class/graphics/fbcon/cursor_blink 2>/dev/null || true
	fi
}

case "$1" in
	start|restart)
		fix_console_permissions
		(
			for delay in 1 3 5; do
				sleep "$delay"
				fix_console_permissions
			done
		) &
		;;
	stop)
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
		;;
esac

exit 0
