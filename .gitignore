# Large/manual downloads
downloads/*
!downloads/README.md
!downloads/firmware/
downloads/firmware/**
!downloads/sdk/
downloads/sdk/**
!downloads/tools/
downloads/tools/**
!downloads/tools/**/
!downloads/tools/**/README.md
!downloads/**/.gitkeep

# Local upstream checkouts; keep them as independent git repos
upstream/*
!upstream/README.md

# Local implementation worktrees
.worktrees/

# Build and flash artifacts
artifacts/*
!artifacts/README.md
!artifacts/firmware/
artifacts/firmware/**
!artifacts/firmware/**/README.md
!artifacts/sd/
artifacts/sd/**
!artifacts/sd/README.md
!artifacts/wifi/
artifacts/wifi/**
!artifacts/wifi/README.md
artifacts/screenshots/
output/
rockdev/
*.img
*.bin
*.tar
*.tar.gz
*.zip
*.7z
*.xz
*.ext2
*.ext4
*.ko
examples/c/hello_luckfox

# Logs can be large; keep only curated Markdown notes by default
!logs/
logs/*
!logs/README.md
!logs/*.md
!logs/**/.gitkeep

# Windows/editor noise
__pycache__/
*.pyc
**/secrets.py
**/.env
**/.env.*
**/*password*
**/*passwd*
**/*token*
Thumbs.db
Desktop.ini
.DS_Store
.vscode/
.idea/
